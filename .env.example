# Copy to /etc/mochan/config.env on the server (chmod 0640, owner root:mochan).
# Values below are PLACEHOLDERS — never commit a real config.

# Where to listen. Pick the form that matches your reverse proxy:
#   - Native (Caddy/nginx on the host):              127.0.0.1:38421
#   - Reverse proxy in Docker (NPM/Traefik/Caddy):   172.17.0.1:38421
#       (Docker bridge IP; private, only reachable from containers + host.
#        Also add `After=docker.service` to the systemd unit.)
#   - Last-resort:                                   0.0.0.0:38421
#       (must add iptables/ufw rule blocking external access to this port)
MOCHAN_LISTEN=127.0.0.1:38421

MOCHAN_USERNAME=admin

# Generate with:  printf 'YOUR_PASSWORD' | mochan hash-password
MOCHAN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# Generate with:  mochan gen-secret
# Must be at least 32 bytes. Rotating this invalidates all existing tokens.
MOCHAN_JWT_SECRET=REPLACE_WITH_RANDOM_HEX

MOCHAN_TOKEN_TTL=24h
MOCHAN_DATA_DIR=/var/lib/mochan

# OS user that interactive shells will run as. Defaults to the service user
# (`mochan`). Give this account NOPASSWD sudo if you want apt/install access.
MOCHAN_SHELL_USER=mochan

# Email used for the bootstrap admin row when the SQLite users table is
# empty. Optional; if missing the admin gets <username>@local. After
# bootstrap the admin can register additional users by issuing invite
# codes via `mochan invite create [--email=...]`.
MOCHAN_EMAIL=admin@example.com

# SQLite path for users / invites / verifications. Defaults to
# $MOCHAN_DATA_DIR/mochan.db. Override only if you need it elsewhere.
# MOCHAN_DB_PATH=/var/lib/mochan/mochan.db

# Resend (https://resend.com) credentials for sending registration and
# password-reset codes. Required for invitee self-registration; without
# them /api/verify/send returns 503.
MOCHAN_RESEND_API_KEY=
MOCHAN_RESEND_FROM_EMAIL=mochan-linux <noreply@auth.mochance.xyz>

# How long an issued invite code stays valid. Default 7 days.
MOCHAN_INVITE_TTL=168h
